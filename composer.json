{
  "name": "katsarov-design/social-media-scheduler",
  "description": "WordPress plugin for Sebeotkrivatel social media scheduling.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "autoload": {
    "psr-4": {
      "KatsarovDesign\\SocialMediaScheduler\\": "includes/"
    }
  },
  "scripts": {
    "lint:syntax": "find . -path ./vendor -prune -o -name '*.php' -print0 | xargs -0 -n1 php -l",
    "lint:phpcs": "phpcs",
    "test": "php tests/CryptoTest.php",
    "test:phpunit": "phpunit -c phpunit.xml.dist",
    "i18n:pot": "wp i18n make-pot . languages/social-media-scheduler.pot --exclude=vendor,node_modules",
    "i18n:json": "wp i18n make-json languages --no-purge"
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpunit/phpunit": "^9.6",
    "wp-coding-standards/wpcs": "^3.1",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
